# Copy to .env and fill in real values. Never commit .env.

# Match CI behavior: 1 retry, retain-on-failure traces, GitHub reporter.
CI=true

DIDAXIS_URL=https://test.didaxis.studio
DIDAXIS_EMAIL=your-admin@example.com
DIDAXIS_PASSWORD=your-password
DIDAXIS_API_TOKEN=your-didaxis-api-token

# Optional — required for Editor/Viewer role tests (e.g. ds6-role-access)
DIDAXIS_EDITOR_EMAIL=your-editor@example.com
DIDAXIS_EDITOR_PASSWORD=your-editor-password
DIDAXIS_VIEWER_EMAIL=your-viewer@example.com
DIDAXIS_VIEWER_PASSWORD=your-viewer-password

ATLASSIAN_BASE_URL=https://your-site.atlassian.net/
ATLASSIAN_EMAIL=your-atlassian-email@example.com
ATLASSIAN_API_TOKEN=your-atlassian-api-token

JIRA_PROJECT_KEY=DS
JIRA_LOGIN_EMAIL=your-jira-login@example.com
JIRA_LOGIN_PASSWORD=your-jira-password

# Cursor CLI / test-generation workflow (also set CURSOR_API_KEY in GitHub dev1 secrets)
CURSOR_API_KEY=your-cursor-api-key
# GitHub PAT for Cursor MCP (repo + actions:read). Never commit this.
CURSOR_GH_MCP=your-github-pat
