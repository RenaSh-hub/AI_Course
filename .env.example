# Copy to .env and fill in real values. Never commit .env.
# Placeholder values only — never put real secrets in this file.

# -----------------------------------------------------------------------------
# Run tests (required to clone and run Playwright)
# -----------------------------------------------------------------------------

# Base URL for Didaxis Studio (Playwright baseURL)
DIDAXIS_URL=https://test.didaxis.studio

# Primary account used by auth setup → playwright/.auth/user.json
DIDAXIS_EMAIL=your-email@example.com

# Password for DIDAXIS_EMAIL (never commit the real value)
DIDAXIS_PASSWORD=your-password

# Bearer token for REST cleanup / API helpers (GET/DELETE /api/programs, etc.)
DIDAXIS_API_TOKEN=your-didaxis-api-token

# Optional — second account for permission / access probes
DIDAXIS_ALT_EMAIL=your-alt-email@example.com
DIDAXIS_ALT_PASSWORD=your-alt-password

# -----------------------------------------------------------------------------
# Agent / CI setup (not needed for npx playwright test alone)
# -----------------------------------------------------------------------------

# Cursor CLI / headless agent (.github/workflows/test-generation.yml)
CURSOR_API_KEY=your-cursor-api-key

# Atlassian API token (Jira REST for backlog automation; also configure MCP in Cursor settings)
ATLASSIAN_API_TOKEN=your-atlassian-api-token

# Atlassian site root, e.g. https://your-site.atlassian.net
ATLASSIAN_BASE_URL=https://your-site.atlassian.net

# Atlassian account email paired with ATLASSIAN_API_TOKEN
ATLASSIAN_EMAIL=your-atlassian-email@example.com
